# Auth.js session encryption secret — generate with: npx auth secret
AUTH_SECRET=

# Google OAuth credentials — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://localhost:3000/api/auth/callback/google
# (dev server runs on https via --experimental-https, see package.json "dev" script)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
